{
  "name": "@gridlore/shell-web",
  "version": "0.0.0",
  "private": true,
  "description": "Web shell for GRIDLORE — Vite + React + PixiJS.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
