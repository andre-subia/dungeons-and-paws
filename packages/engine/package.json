{
  "name": "@gridlore/engine",
  "version": "0.0.0",
  "private": true,
  "description": "Deterministic game engine for GRIDLORE. Pure TypeScript, no UI deps.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "vitest": "^2.1.5",
    "fast-check": "^3.23.1",
    "typescript": "^5.6.3"
  }
}
