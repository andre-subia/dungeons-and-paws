{
  "name": "gridlore",
  "version": "0.0.0",
  "private": true,
  "description": "GRIDLORE — procedural dungeon-puzzle roguelike",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "dev": "pnpm --filter @gridlore/shell-web run dev",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  },
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=20"
  }
}
